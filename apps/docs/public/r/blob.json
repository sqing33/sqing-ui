  "files": [
    {
      "name": "index.tsx",
      "path": "blob/index.tsx",
      "content": "'use client'\n\nimport * as React from 'react'\nimport { cn } from '../../utils/cn'\n\nexport interface BlobProps {\n  /** 斑点尺寸 */\n  size?: number\n  /** 斑点颜色 */\n  color?: string\n  /** 变形速度（秒） */\n  speed?: number\n  /** 自定义 className */\n  className?: string\n}\n\n// 多个随机的 SVG path（模拟液体斑点）\nconst PATHS = [\n  'M44.1,-69.5C56.1,-60.3,63.7,-44.6,67.7,-28.9C71.7,-13.2,72.1,2.4,67.4,15.8C62.7,29.2,52.9,40.4,41.3,49.8C29.7,59.2,16.3,66.8,1.7,64.5C-12.9,62.2,-28.7,50,-40.4,37C-52.1,24,-59.7,10.2,-60.8,-4.3C-61.9,-18.8,-56.5,-34,-45.7,-43.1C-34.9,-52.2,-18.7,-55.2,-1.8,-52.8C15.1,-50.4,32.1,-78.7,44.1,-69.5Z',\n  'M40.5,-67.1C52.6,-58.5,62.3,-46.1,67.8,-32.2C73.3,-18.3,74.6,-2.9,71.6,11.1C68.6,25.1,61.3,37.7,51.2,47.7C41.1,57.7,28.2,65.1,13.9,68.7C-0.4,72.3,-16,72.1,-29.4,66.4C-42.8,60.7,-54,49.5,-61.5,36.3C-69,23.1,-72.8,7.9,-71.1,-6.5C-69.4,-20.9,-62.2,-34.5,-51.7,-43.7C-41.2,-52.9,-27.4,-57.7,-13.4,-62.3C0.6,-66.9,14.8,-71.3,28.4,-75.7Z',\n  'M37.8,-62.4C49.6,-53.4,60.2,-42.2,66.1,-28.7C72,-15.2,73.2,0.7,69.1,14.9C65,29.1,55.7,41.7,44.2,51.5C32.7,61.3,19.1,68.3,3.7,67.9C-11.7,67.5,-28.9,59.7,-41.7,49.4C-54.5,39.1,-62.9,26.3,-67.4,11.8C-71.9,-2.7,-72.5,-18.9,-66.4,-31.4C-60.3,-43.9,-47.6,-52.7,-34.2,-60.2C-20.8,-67.7,-6.7,-73.9,5.7,-73.5C18.1,-73.1,26,-71.4,37.8,-62.4Z',\n  'M42.3,-68.5C54.6,-59.4,63.7,-46,68.4,-31.2C73.1,-16.4,73.4,-0.3,69.7,14.3C66,28.9,58.3,42,47.1,51.7C35.9,61.4,21.2,67.7,5.6,68.4C-10,69.1,-26.5,64.2,-39.7,55.4C-52.9,46.6,-62.8,33.9,-68.4,19.2C-74,4.5,-75.3,-12.2,-70.3,-26.5C-65.3,-40.8,-54,-52.7,-41,-61.9C-28,-71.1,-13.4,-77.6,1.4,-79.9C16.2,-82.2,30,-77.6,42.3,-68.5Z',\n]\n\nexport function Blob({ size = 200, color = '#a855f7', speed = 6, className }: BlobProps) {\n  const [index, setIndex] = React.useState(0)\n\n  React.useEffect(() => {\n    const timer = setInterval(() => {\n      setIndex((prev) => (prev + 1) % PATHS.length)\n    }, speed * 1000)\n    return () => clearInterval(timer)\n  }, [speed])\n\n  return (\n    <div className={cn('inline-block', className)}>\n      <svg\n        viewBox=\"-100 -100 200 200\"\n        width={size}\n        height={size}\n        xmlns=\"http://www.w3.org/2000/svg\"\n        style={{ filter: 'blur(0.5px)' }}\n      >\n        <path\n          d={PATHS[index]}\n          fill={color}\n          style={{\n            transition: `d ${speed}s ease-in-out`,\n          }}\n        />\n      </svg>\n    </div>\n  )\n}\n"
    },
    {
      "name": "demo.tsx",
      "path": "blob/demo.tsx",
      "content": "'use client'\n\nimport { Blob } from './index'\n\nexport function BlobDemo() {\n  return (\n    <div className=\"grid min-h-[400px] w-full grid-cols-1 gap-6 bg-slate-900 p-8 md:grid-cols-3\">\n      <div className=\"flex flex-col items-center justify-center gap-3\">\n        <Blob color=\"#a855f7\" size={200} />\n        <span className=\"text-sm text-white/60\">Purple</span>\n      </div>\n      <div className=\"flex flex-col items-center justify-center gap-3\">\n        <Blob color=\"#06b6d4\" size={200} speed={4} />\n        <span className=\"text-sm text-white/60\">Cyan · Fast</span>\n      </div>\n      <div className=\"flex flex-col items-center justify-center gap-3\">\n        <Blob color=\"#f59e0b\" size={200} speed={8} />\n        <span className=\"text-sm text-white/60\">Orange · Slow</span>\n      </div>\n    </div>\n  )\n}\n"
    }
  ]
}
