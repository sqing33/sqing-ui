{
  "name": "sqing-ui",
  "version": "0.1.0",
  "private": true,
  "description": "A creative UI component library for React - mouse effects, 3D, particles, scroll animations",
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "build": "pnpm --filter @sqing/registry build:registry && pnpm --filter docs build",
    "build:cli": "pnpm --filter @sqing/cli build",
    "registry:build": "pnpm --filter @sqing/registry build:registry",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "cli": "pnpm --filter @sqing/cli dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
